# --- Server ---
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (Postgres) ---
# Local dev on host (tsx):        host = localhost
# Inside docker-compose network:  host = db  (compose overrides this automatically)
DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN=7d

# --- Email (Gmail + App Password, via Nodemailer) ---
# Enable 2FA on the Google account, then create an App Password.
EMAIL_USER="you@gmail.com"
EMAIL_APP_PASSWORD="your-16-char-app-password"
EMAIL_FROM="Ledger <you@gmail.com>"

# --- Postgres container credentials (used by docker-compose) ---
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger
POSTGRES_DB=ledger
